#include "bno055.h"
#include <string.h>

I2C_HandleTypeDef *_bno055_i2c_port;


void bno055_assign(I2C_HandleTypeDef *hi2c_device){
	_bno055_i2c_port = hi2c_device;
}

void bno055_init(){

}


void bno055_writeData(uint8_t reg, uint8_t data){
	HAL_I2C_Mem_Write(_bno055_i2c_port, BNO055_I2C_ADDR_LO<<1 , reg, I2C_MEMADD_SIZE_8BIT, &data, 1, 100);
}

void bno055_readData(uint8_t reg, uint8_t *data, uint8_t len){
	HAL_I2C_Mem_Read(_bno055_i2c_port, BNO055_I2C_ADDR_LO<<1 , reg, I2C_MEMADD_SIZE_8BIT, data, len, 100);
}

void bno055_delay(int time){
	HAL_Delay(time);
}

void bno055_reset(){
	bno055_writeData(SYS_TRIGGER, 0x20);
	bno055_delay(700);
}

uint8_t bno055_setPage(uint8_t page) {
	bno055_writeData(PAGE_ID, page);
}

int8_t bno055_getOperationMode(){
	uint8_t mode;
	bno055_readData(OPR_MODE, &mode, 1);
	return mode;
}

void bno055_setOperationMode(bno055_opmode_t mode){
	bno055_writeData(OPR_MODE, mode);
	bno055_delay(20);
}

void bno055_setOperationModeConfig(){
	bno055_setOperationMode(OP_MODE_CONFIG);
}

void bno055_setOperationModeNDOF(){
	bno055_setOperationMode(OP_MODE_NDOF);
}


bno055_calibration_state_t bno055_getCalibrationState(){
	bno055_setPage(0);
	uint8_t cal;
	bno055_readData(CALIB_STAT, &cal, 1);

	cal.sys = (calState >> 6) & 0x03;
	cal.gyro = (calState >> 4) & 0x03;
	cal.accel = (calState >> 2) & 0x03;
	cal.mag = calState & 0x03;
	return cal;
}

bno055_calibration_data_t bno055_getCalibrationData(){
	bno055_setPage(0);
	bno055_calibration_data_t calData;
	uint8_t buffer[22];

	bno055_opmode_t prevMode = bno055_getOperationMode();
	bno055_setOperationModeConfig();

	bno055_readData(ACC_OFFSET_X_LSB, buffer, 22);

	bno055_setOperationMode(prevMode);

	return calData;
}

