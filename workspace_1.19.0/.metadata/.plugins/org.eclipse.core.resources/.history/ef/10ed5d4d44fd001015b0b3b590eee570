#ifndef INC_DRV8245_Q1_H_
#define INC_DRV8245_Q1_H_


//---------------------------------------------------------------------- register addresses ----------------------------------------------------------------------

//read-only
#define DEVICE_ID 0x00
#define FAULT_SUMMARY 0x01
#define STATUS1 0x02
#define STATUS2 0x03

//read-write
#define COMMAND 0x08
#define SPI_IN 0x09
#define CONFIG1 0x0A
#define CONFIG2 0x0B
#define CONFIG3 0x0C
#define CONFIG4 0x0D

//---------------------------------------------------------------------- register fields ----------------------------------------------------------------------

//FAULT_SUMMARY
#define FAULT_SUMMARY_SPI_ERR 0x80
#define FAULT_SUMMARY_POR 0x40
#define FAULT_SUMMARY_FAULT 0x20
#define FAULT_SUMMARY_VMOV 0x10
#define FAULT_SUMMARY_VMUV 0x08
#define FAULT_SUMMARY_OCP 0x04
#define FAULT_SUMMARY_TSD 0x02
#define FAULT_SUMMARY_OLA 0x01

//STATUS1
#define STATUS1_OLA1 0x80
#define STATUS1_OLA2 0x40
#define STATUS1_ITRIP_CMP 0x20
#define STATUS1_ACTIVE 0x10
#define STATUS1_OCP_H1 0x08
#define STATUS1_OCP_L1 0x04
#define STATUS1_OCP_H2 0x02
#define STATUS1_OCP_L2 0x01

//STATUS2
#define STATUS2_DRVOFF_STAT 0x80
#define STATUS2_ACTIVE 0x10
#define STATUS2_OLP_CMP 0x01

//COMMAND
#define COMMAND_CLR_FLT 0x80
#define COMMAND_SPI_IN_LOCK 0x18 //bits 4:3
#define COMMAND_REG_LOCK 0x03 //bits 1:0

//SPI_IN
#define SPI_IN_S_DRVOFF 0x08
#define SPI_IN_S_DRVOFF2 0x04
#define SPI_IN_S_EN_IN1 0x02
#define SPI_IN_S_PH_IN2 0x01

//CONFIG1
#define CONFIG1_EN_OLA 0x80
#define CONFIG1_VMOV_SEL 0x60
#define CONFIG1_SSC_DIS 0x10
#define CONFIG1_OCP_RETRY 0x08
#define CONFIG1_TSD_RETRY 0x04
#define CONFIG1_VMOV_RETRY 0x02
#define CONFIG1_OLA_RETRY 0x01

//CONFIG2
#define CONFIG2_PWM_EXTEND 0x80
#define CONFIG2_S_DIAG 0x60
#define CONFIG2_S_ITRIP 0x07

//CONFIG3
#define CONFIG3_TOFF 0xC0
#define CONFIG3_S_SR 0x1C
#define CONFIG3_S_MODE 0x03

//CONFIG4
#define CONFIG4_TOCP_SEL 0xC0
#define CONFIG4_OCP_SEL 0x18
#define CONFIG4_DRVOFF_SEL 0x04
#define CONFIG4_EN_IN1_SEL 0x02
#define CONFIG4_PH_IN2_SEL 0x01

//---------------------------------------------------------------------- structs ----------------------------------------------------------------------

typedef struct {
    SPI_HandleTypeDef *hspi;
    GPIO_TypeDef *csPort;
    uint16_t csPin;
    GPIO_TypeDef *sleepPort;       // nSLEEP Port (Hardware Enable)
    uint16_t sleepPin;             // nSLEEP Pin
    GPIO_TypeDef *faultPort;       // nFAULT Port (Input)
    uint16_t faultPin;             // nFAULT Pin

    uint8_t ctrl_regs[0x0E];
} drv8245_handle_t;

//---------------------------------------------------------------------- functions ----------------------------------------------------------------------

void drv8245_assign(SPI_HandleTypeDef *hspi_device);
void drv8245_readData();
void drv8245_writeData();
void drv8245_updateData(); //helper

void drv8245_init();
void drv8245_setSlewRate();
void drv8245_setOCR();
void drv8245_setBridgeMode();
void drv8245_reset();

void drv8245_setSpiControl();
void drv8245_setDriveOutput();
void drv8245_lockReg();
void drv8245_unlockReg();

void drv8245_getFaultSummary();
void drv8245_clearFaults();
#endif /* INC_DRV8245_Q1_H_ */
