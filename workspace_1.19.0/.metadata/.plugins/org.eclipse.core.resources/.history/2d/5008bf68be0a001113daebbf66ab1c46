//makes printf redirect to usb
int _write(int file, char *ptr, int len) {
	uint8_t result = USBD_OK;
	uint32_t start_tick = HAL_GetTick();
	uint32_t timeout_ms = 10;

	do {
		result = CDC_Transmit_FS((uint8_t *)ptr, len);

		//if timed out
		if ((HAL_GetTick() - start_tick) > timeout_ms) {
			return 0;
		}

	} while (result == USBD_BUSY);

	if (result == USBD_OK) {
		return len;
	} else {
		return 0;
	}
}

uint8_t piSendReceive(uint8_t* receiveData, bno055_data_vector imu_position, uint16_t encoder1, uint16_t encoder2){

	//create transmit buffer
	uint8_t tx_buffer[TX_BUFFER_SIZE];

	tx_buffer[0] = 0xAA;

	memcpy(&tx_buffer[1], &imu_position.w, 8);
	memcpy(&tx_buffer[9], &imu_position.x, 8);
	memcpy(&tx_buffer[17], &imu_position.y, 8);
	memcpy(&tx_buffer[25], &imu_position.z, 8);
	memcpy(&tx_buffer[33], &encoder1, 2);
	memcpy(&tx_buffer[35], &encoder2, 2);

	tx_buffer[37] = 0x55; //use index sizeof(tx_buffer) - 1

	//check receive buffer
	if (receiveData == NULL) {
	        printf("Error: receiveData pointer is NULL\r\n");
	        return -3;
	    }

	//send
	uint8_t sendStatus = HAL_UART_Transmit(&huart2, tx_buffer, 38, 1000);
		if (sendStatus != HAL_OK){
				printf("transmission error\r\n");
				return -2;
			}
		else{
			printf("transmission successful\r\n");
		}

	HAL_Delay(10);

	uint8_t receiveStatus = HAL_UART_Receive(&huart2, receiveData, RX_BUFFER_SIZE, 1000);
	    if (receiveStatus != HAL_OK) {
	        if (receiveStatus == HAL_TIMEOUT) {
	            printf("Receive timeout - no data received\r\n");

	            // Try to receive just 1 byte to test
	            uint8_t test_byte;
	            if (HAL_UART_Receive(&huart2, &test_byte, 1, 100) == HAL_OK) {
	                printf("Partial data detected: 0x%02X\r\n", test_byte);
	            } else {
	                printf("No data available at all\r\n");
	            }
	        } else {
	            printf("Receive error: %d\r\n", receiveStatus);
	        }
	        return -1;
	    }
//	//receive
//	uint8_t receiveStatus = HAL_UART_Receive(&huart2, receiveData, 38, 1000);
//	printf("data received \r\n");
//	if (receiveStatus != HAL_OK) {
//	        if (receiveStatus == HAL_TIMEOUT) {
//	            printf("receive timeout\r\n");
//	        } else {
//	            printf("receive error: %d\r\n", receiveStatus);
//	        }
//	        return -1;
//	    }

	//debug line, comment out as needed
	printf("Received: ");
	    for(int i = 0; i < RX_BUFFER_SIZE; i++) {
	        printf("%02X ", receiveData[i]);
	    }
	    printf("\r\n");



	return 0;
}

void uart_loopback_test() {
	    uint8_t tx_byte = 0xAA;
	    uint8_t rx_byte = 0x00;

	    printf("\r\n=== UART Loopback Test ===\r\n");
	    printf("UART Mode: 0x%08lX\r\n", huart2.Init.Mode);
	    printf("Expected: 0x%08X (UART_MODE_TX_RX)\r\n", UART_MODE_TX_RX);

	    // Test 1: Can we transmit?
	    printf("\r\nTest 1: Transmitting 0x%02X...\r\n", tx_byte);
	    HAL_StatusTypeDef tx_status = HAL_UART_Transmit(&huart2, &tx_byte, 1, 100);
	    printf("TX Status: %d (0=OK, 3=TIMEOUT)\r\n", tx_status);

	    // Small delay
	    HAL_Delay(10);

	    // Test 2: Can we receive?
	    printf("\r\nTest 2: Waiting to receive 1 byte...\r\n");
	    HAL_StatusTypeDef rx_status = HAL_UART_Receive(&huart2, &rx_byte, 1, 1000);
	    printf("RX Status: %d (0=OK, 3=TIMEOUT)\r\n", rx_status);

	    if (rx_status == HAL_OK) {
	        printf("Received: 0x%02X\r\n", rx_byte);
	        if (rx_byte == tx_byte) {
	            printf("✓ SUCCESS: Loopback working!\r\n");
	        } else {
	            printf("✗ FAIL: Data mismatch (sent 0x%02X, got 0x%02X)\r\n", tx_byte, rx_byte);
	        }
	    } else {
	        printf("✗ FAIL: No data received\r\n");

	        // Check UART flags
	        printf("\r\nUART Flags:\r\n");
	        printf("  RXNE (RX Not Empty): %d\r\n", __HAL_UART_GET_FLAG(&huart2, UART_FLAG_RXNE));
	        printf("  TXE  (TX Empty): %d\r\n", __HAL_UART_GET_FLAG(&huart2, UART_FLAG_TXE));
	        printf("  TC   (TX Complete): %d\r\n", __HAL_UART_GET_FLAG(&huart2, UART_FLAG_TC));
	        printf("  ORE  (Overrun): %d\r\n", __HAL_UART_GET_FLAG(&huart2, UART_FLAG_ORE));
	    }

	    printf("\r\n=== Test Complete ===\r\n");
	}

