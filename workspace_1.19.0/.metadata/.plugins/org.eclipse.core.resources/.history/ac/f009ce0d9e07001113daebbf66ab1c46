bno055_data_vector bno055_getVectorGravity(){
	return bno055_getVector(BNO055_VECTOR_GRAVITY);
}

bno055_data_vector bno055_getVectorQuaternion(){
	return bno055_getVector(BNO055_VECTOR_QUATERNION);
}



