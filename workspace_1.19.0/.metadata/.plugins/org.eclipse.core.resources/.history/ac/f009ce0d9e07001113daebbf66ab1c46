    printf("\n=== I2C Hardware Check ===\r\n");

    // Check if I2C peripheral is enabled
    printf("I2C State: %d (0=RESET, 1=READY, 2=BUSY, others=ERROR)\r\n",
           _bno055_i2c_port->State);

    // Manually check GPIO states
    GPIO_PinState scl = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_9); // Adjust pins
    GPIO_PinState sda = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_8);

    printf("SCL pin: %d, SDA pin: %d (1=HIGH, 0=LOW)\r\n", scl, sda);
    printf("Both should be HIGH when idle\r\n");
}

void i2c_bus_scan() {
    printf("\n=== I2C Bus Scan ===\r\n");
    printf("Scanning I2C bus...\r\n");

    uint8_t devices_found = 0;

    for (uint8_t addr = 1; addr < 128; addr++) {
        HAL_StatusTypeDef result = HAL_I2C_IsDeviceReady(_bno055_i2c_port,
                                                          addr << 1,
                                                          1,
                                                          10);

        if (result == HAL_OK) {
            printf("Device found at address: 0x%02X\r\n", addr);
            devices_found++;
        }
    }

    if (devices_found == 0) {
        printf("No I2C devices found!\r\n");
    } else {
        printf("Total devices found: %d\r\n", devices_found);
    }
}

