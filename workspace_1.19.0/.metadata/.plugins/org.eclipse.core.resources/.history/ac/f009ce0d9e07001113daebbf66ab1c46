void i2c_force_recovery() {
    printf("\n=== I2C Recovery Procedure ===\r\n");

    // Method 1: Reset I2C peripheral
    printf("Resetting I2C peripheral...\r\n");
    HAL_I2C_DeInit(_bno055_i2c_port);
    HAL_Delay(100);
    HAL_I2C_Init(_bno055_i2c_port);
    HAL_Delay(100);

    // Method 2: Toggle SCL to clear stuck bus
    printf("Attempting bus clear by toggling SCL...\r\n");

    // Temporarily configure SCL as GPIO output
    GPIO_InitTypeDef GPIO_InitStruct = {0};
    GPIO_InitStruct.Pin = GPIO_PIN_6; // Adjust to your SCL pin
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
    HAL_GPIO_Init(GPIOB, &GPIO_InitStruct); // Adjust port

    // Generate 9 clock pulses
    for (int i = 0; i < 9; i++) {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_RESET);
        HAL_Delay(1);
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_SET);
        HAL_Delay(1);
    }

    // Reconfigure as I2C
    MX_I2C1_Init(); // Your I2C init function

    printf("Recovery complete\r\n");
}

void test_bno055_basic() {
    printf("\n=== BNO055 Basic Test ===\r\n");

    // Test 1: Device ready check
    printf("Test 1: Device ready check...\r\n");
    HAL_StatusTypeDef status = HAL_I2C_IsDeviceReady(_bno055_i2c_port,
                                                      BNO055_I2C_ADDR << 1,
                                                      3, 1000);
    printf("Result: %d (0=OK)\r\n", status);

    if (status != HAL_OK) {
        printf("FAILED: Device not responding\r\n");
        return;
    }

    // Test 2: Read Chip ID
    printf("\nTest 2: Read Chip ID...\r\n");
    uint8_t chip_id = 0;
    bno055_readData(CHIP_ID, &chip_id, 1);
    printf("Chip ID: 0x%02X (expected 0xA0)\r\n", chip_id);

    // Test 3: Read multiple registers
    printf("\nTest 3: Read multiple IDs...\r\n");
    uint8_t ids[4];
    bno055_readData(CHIP_ID, ids, 4);
    printf("CHIP_ID: 0x%02X\r\n", ids[0]);
    printf("ACC_ID: 0x%02X\r\n", ids[1]);
    printf("MAG_ID: 0x%02X\r\n", ids[2]);
    printf("GYR_ID: 0x%02X\r\n", ids[3]);
}
