#ifndef INC_DRV8245_Q1_H_
#define INC_DRV8245_Q1_H_

#include "main.h"
#include "stm32g4xx_hal.h"
#include <stdbool.h>


//---------------------------------------------------------------------- register addresses ----------------------------------------------------------------------

//read-only
#define DEVICE_ID 0x00
#define FAULT_SUMMARY 0x01
#define STATUS1 0x02
#define STATUS2 0x03

//read-write
#define COMMAND 0x08
#define SPI_IN 0x09
#define CONFIG1 0x0A
#define CONFIG2 0x0B
#define CONFIG3 0x0C
#define CONFIG4 0x0D

//---------------------------------------------------------------------- register fields ----------------------------------------------------------------------

//FAULT_SUMMARY
#define FAULT_SUMMARY_SPI_ERR 0x80
#define FAULT_SUMMARY_POR 0x40
#define FAULT_SUMMARY_FAULT 0x20
#define FAULT_SUMMARY_VMOV 0x10
#define FAULT_SUMMARY_VMUV 0x08
#define FAULT_SUMMARY_OCP 0x04
#define FAULT_SUMMARY_TSD 0x02
#define FAULT_SUMMARY_OLA 0x01

//STATUS1
#define STATUS1_OLA1 0x80
#define STATUS1_OLA2 0x40
#define STATUS1_ITRIP_CMP 0x20
#define STATUS1_ACTIVE 0x10
#define STATUS1_OCP_H1 0x08
#define STATUS1_OCP_L1 0x04
#define STATUS1_OCP_H2 0x02
#define STATUS1_OCP_L2 0x01

//STATUS2
#define STATUS2_DRVOFF_STAT 0x80
#define STATUS2_ACTIVE 0x10
#define STATUS2_OLP_CMP 0x01

//COMMAND
#define COMMAND_CLR_FLT 0x80
#define COMMAND_SPI_IN_LOCK 0x18 //bits 4:3
#define COMMAND_REG_LOCK 0x03 //bits 1:0

//SPI_IN
#define SPI_IN_S_DRVOFF 0x08
#define SPI_IN_S_DRVOFF2 0x04
#define SPI_IN_S_EN_IN1 0x02
#define SPI_IN_S_PH_IN2 0x01

//CONFIG1
#define CONFIG1_EN_OLA 0x80
#define CONFIG1_VMOV_SEL 0x60
#define CONFIG1_SSC_DIS 0x10
#define CONFIG1_OCP_RETRY 0x08
#define CONFIG1_TSD_RETRY 0x04
#define CONFIG1_VMOV_RETRY 0x02
#define CONFIG1_OLA_RETRY 0x01

//CONFIG2
#define CONFIG2_PWM_EXTEND 0x80
#define CONFIG2_S_DIAG 0x60
#define CONFIG2_S_ITRIP 0x07

//CONFIG3
#define CONFIG3_TOFF 0xC0
#define CONFIG3_S_SR 0x1C
#define CONFIG3_S_MODE 0x03

//CONFIG4
#define CONFIG4_TOCP_SEL 0xC0
#define CONFIG4_OCP_SEL 0x18
#define CONFIG4_DRVOFF_SEL 0x04
#define CONFIG4_EN_IN1_SEL 0x02
#define CONFIG4_PH_IN2_SEL 0x01

//---------------------------------------------------------------------- constants ----------------------------------------------------------------------

#define DRV8245P_DEVICE_ID 0x56

//driver operating modes
#define DRV8245_MODE_PH_EN 0x00
#define DRV8245_MODE_INDEPENDENT 0x01
#define DRV8245_MODE_PWM 0x02

//errors
#define DRV8245_OK 0x00
#define DRV8245_ERR_SPI 0x01
#define DRV8245_ERR_TIMEOUT 0x02
#define DRV8245_ERR_FAULT 0x03
#define DRV8245_ERR_PARAM 0x04

void drv8245_assign(SPI_HandleTypeDef *spi_device);

/******************************************************************************
 * PHASE 1: LOW-LEVEL SPI & BASIC COMMUNICATION
 * Implement these first - foundation for everything else
 *****************************************************************************/

// 1.1 Core SPI Functions
uint8_t drv8245_spi_transfer_16bit(uint16_t tx_data, uint16_t *rx_data);
uint8_t drv8245_spi_transfer_chain(uint16_t *tx_cmds, uint16_t *rx_data, uint8_t chain_len);

uint8_t drv8245_spi_write_register(uint8_t address, uint8_t data);
uint8_t drv8245_spi_read_register(uint8_t address, uint8_t *data);

// 1.2 Device Identification
uint8_t drv8245_get_device_id(uint8_t *id);  // Should return 0x56 for SPI(P)
uint8_t drv8245_check_spi_error(void);

/******************************************************************************
 * PHASE 2: DEVICE INITIALIZATION & POWER MANAGEMENT
 * Implement after SPI is working
 *****************************************************************************/

// 2.1 Initialization Sequence
uint8_t drv8245_init(void);  // Complete initialization
void drv8245_wait_ready(void);  // Wait for tREADY after power-up
uint8_t drv8245_clear_faults(void);  // Send CLR_FAULT command
uint8_t drv8245_reset(void);

// 2.2 State Management
bool drv8245_is_ready(void);
uint8_t drv8245_get_device_state(void);  // SLEEP/STANDBY/ACTIVE
uint8_t drv8245_enter_standby(void);
uint8_t drv8245_enter_active(void);

/******************************************************************************
 * PHASE 3: REGISTER LOCKING & PROTECTION
 * Implement to secure configuration
 *****************************************************************************/

// 3.1 Configuration Protection
uint8_t drv8245_lock_config_registers(void);    // REG_LOCK = 10b
uint8_t drv8245_unlock_config_registers(void);  // REG_LOCK = 01b
uint8_t drv8245_lock_spi_input(void);           // SPI_IN_LOCK = 01b
uint8_t drv8245_unlock_spi_input(void);         // SPI_IN_LOCK = 10b

/******************************************************************************
 * PHASE 4: BASIC MOTOR CONTROL CONFIGURATION
 * Core configuration for Independent mode (2 motors)
 *****************************************************************************/

// 4.1 Operating Mode Setup
uint8_t drv8245_set_mode(uint8_t mode);  // S_MODE bits
uint8_t drv8245_set_independent_mode(void);  // S_MODE = 01b for 2 motors
uint8_t drv8245_set_bridge_mode(void);       // For single H-bridge

// 4.2 Pin Control Logic
uint8_t drv8245_set_drvoff_logic(uint8_t mode);   // DRVOFF_SEL (AND/OR)
uint8_t drv8245_set_en_in1_logic(uint8_t mode);   // EN_IN1_SEL (AND/OR)
uint8_t drv8245_set_ph_in2_logic(uint8_t mode);   // PH_IN2_SEL (AND/OR)

/******************************************************************************
 * PHASE 5: MOTOR CONTROL VIA SPI_IN REGISTER
 * Direct control bits when SPI_IN is unlocked
 *****************************************************************************/

// 5.1 Direct SPI Control Bits
uint8_t drv8245_set_drvoff(bool state);   // S_DRVOFF bit (motor 1)
uint8_t drv8245_set_drvoff2(bool state);  // S_DRVOFF2 bit (motor 2)
uint8_t drv8245_set_en_in1(bool state);   // S_EN_IN1 bit
uint8_t drv8245_set_ph_in2(bool state);   // S_PH_IN2 bit

/******************************************************************************
 * PHASE 6: HIGH-LEVEL MOTOR CONTROL
 * User-friendly motor control functions
 *****************************************************************************/

// 6.1 Motor 1 Control (Independent Mode)
uint8_t drv8245_motor1_forward(uint8_t duty_cycle);
uint8_t drv8245_motor1_reverse(uint8_t duty_cycle);
uint8_t drv8245_motor1_brake(void);
uint8_t drv8245_motor1_coast(void);  // Hi-Z

// 6.2 Motor 2 Control (Independent Mode)
uint8_t drv8245_motor2_forward(uint8_t duty_cycle);
uint8_t drv8245_motor2_reverse(uint8_t duty_cycle);
uint8_t drv8245_motor2_brake(void);
uint8_t drv8245_motor2_coast(void);  // Hi-Z

// 6.3 Combined Control
uint8_t drv8245_all_stop(void);

/******************************************************************************
 * PHASE 7: PROTECTION & CURRENT LIMITING
 * Safety features configuration
 *****************************************************************************/

// 7.1 Current Regulation
uint8_t drv8245_set_itrip_level(uint8_t level);     // 0-6, 7=disable
uint8_t drv8245_set_toff_time(uint8_t time);        // 20/30/40/50 µs
bool drv8245_check_itrip_status(void);              // Read ITRIP_CMP

// 7.2 Overcurrent Protection
uint8_t drv8245_set_ocp_threshold(uint8_t threshold);     // OCP_SEL 0-2
uint8_t drv8245_set_ocp_filter_time(uint8_t time);        // Deglitch time
uint8_t drv8245_check_ocp(void);
uint8_t drv8245_check_ocp_specific(uint8_t channel, uint8_t side);  // H1/L1/H2/L2

// 7.3 Voltage Monitoring
uint8_t drv8245_set_vmov_threshold(uint8_t threshold);  // >35V, >28V, >18V, disabled
uint8_t drv8245_check_vmov(void);  // Overvoltage
uint8_t drv8245_check_vmuv(void);  // Undervoltage (important for SPI(P))

// 7.4 Thermal Protection
uint8_t drv8245_check_tsd(void);  // Thermal shutdown

/******************************************************************************
 * PHASE 8: FAULT MANAGEMENT
 * Fault reaction configuration and handling
 *****************************************************************************/

// 8.1 Fault Reaction Configuration
uint8_t drv8245_set_ocp_retry(bool enable);   // Retry vs latched
uint8_t drv8245_set_tsd_retry(bool enable);
uint8_t drv8245_set_vmov_retry(bool enable);
uint8_t drv8245_set_ola_retry(bool enable);

// 8.2 Fault Status Reading
uint8_t drv8245_read_fault_summary(uint8_t *faults);  // FAULT_SUMMARY register
uint8_t drv8245_read_status1(uint8_t *status);        // OCP flags, ITRIP_CMP, ACTIVE
uint8_t drv8245_read_status2(uint8_t *status);        // DRVOFF_STAT, OLP_CMP
uint8_t drv8245_check_por(void);  // Power-on reset flag

/******************************************************************************
 * PHASE 9: DIAGNOSTICS
 * Load diagnostics and monitoring
 *****************************************************************************/

// 9.1 Load Diagnostics Configuration
uint8_t drv8245_enable_ola(bool enable);        // On-state (active) diagnostics
uint8_t drv8245_set_diag_mode(uint8_t mode);    // Load type indication (S_DIAG)

// 9.2 Diagnostic Status
uint8_t drv8245_check_ola(void);               // Open load in active state
uint8_t drv8245_read_olp_comparator(void);     // Off-state diagnostics
uint8_t drv8245_check_active_state(void);      // Device in ACTIVE state
uint8_t drv8245_get_drvoff_pin_status(void);

/******************************************************************************
 * PHASE 10: CURRENT MONITORING (IPROPI)
 * Requires external ADC
 *****************************************************************************/

// 10.1 Current Sense Functions
uint8_t drv8245_read_ipropi_voltage(float *voltage);  // Requires external ADC
float drv8245_calculate_load_current(float ipropi_voltage);

/******************************************************************************
 * PHASE 11: ADVANCED FEATURES
 * Optional performance optimizations
 *****************************************************************************/

// 11.1 Slew Rate Control
uint8_t drv8245_set_slew_rate(uint8_t rate);  // S_SR: 0-7 (8 levels)

// 11.2 EMI Reduction
uint8_t drv8245_enable_spread_spectrum(bool enable);  // Spread spectrum clocking

// 11.3 PWM Features
uint8_t drv8245_set_pwm_extend(bool enable);  // Additional Hi-Z states

/******************************************************************************
 * PHASE 12: UTILITY & ERROR HANDLING
 * Support functions
 *****************************************************************************/

// 12.1 Error Management
uint8_t drv8245_get_last_error(void);
void drv8245_clear_error_flags(void);
const char* drv8245_fault_to_string(uint8_t fault_code);

// 12.2 External Components Documentation
void drv8245_configure_external_components(void);  // Reference implementation

#endif /* INC_DRV8245_Q1_H_ */
