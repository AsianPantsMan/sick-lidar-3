uint8_t MD2_motor_init(){
	printf("nSLEEP asserted on motor driver 2\r\n");
	HAL_GPIO_WritePin(MD2_nSLEEP_GPIO_Port, MD2_nSLEEP_Pin, GPIO_PIN_SET);
	HAL_Delay(20);

	GPIO_PinState init_status = HAL_GPIO_ReadPin(MD2_nSLEEP_GPIO_Port, MD2_nSLEEP_Pin);
	while (init_status == GPIO_PIN_SET){
		printf("waiting for nSLEEP to de-assert...\r\n");
		HAL_Delay(100);
	}
	HAL_GPIO_WritePin(MD2_LED_GPIO_Port, MD2_LED_Pin, GPIO_PIN_SET);
	printf("nSLEEP de-asserted, motor driver 2 ready\r\n");
}

uint8_t MD1_setSpeed(TIM_HandleTypeDef *htim, uint32_t channel, uint8_t duty){

	//phase debug
	GPIO_PinState phase = HAL_GPIO_ReadPin(MD1_PH_IN2_GPIO_Port, MD1_PH_IN2_Pin);
	printf("motor driver 1 phase: %d\r\n", phase);

	__HAL_TIM_SET_COMPARE(htim, channel, duty);

	return (uint8_t)((duty * 100) / 1000);
}
