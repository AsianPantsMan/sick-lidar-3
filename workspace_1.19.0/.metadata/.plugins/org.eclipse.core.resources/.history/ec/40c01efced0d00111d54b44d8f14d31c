uint8_t MD1_setSpeed(TIM_HandleTypeDef *htim, uint32_t channel, uint8_t duty) {
	if (duty > 100) {
		printf("ERROR: Invalid duty cycle %d%%\r\n", duty);
		return 0;
	}

	// Debug: DRVOFF pin state before and after
	GPIO_PinState drvoff_state_before = HAL_GPIO_ReadPin(MD1_DRVOFF_GPIO_Port, MD1_DRVOFF_Pin);
	printf("[DEBUG] MD1_DRVOFF before: %d\r\n", drvoff_state_before);
	HAL_GPIO_WritePin(MD1_DRVOFF_GPIO_Port, MD1_DRVOFF_Pin, GPIO_PIN_RESET);
	GPIO_PinState drvoff_state_after = HAL_GPIO_ReadPin(MD1_DRVOFF_GPIO_Port, MD1_DRVOFF_Pin);
	printf("[DEBUG] MD1_DRVOFF after: %d\r\n", drvoff_state_after);

	// Debug: phase pin
	GPIO_PinState phase = HAL_GPIO_ReadPin(MD1_PH_IN2_GPIO_Port, MD1_PH_IN2_Pin);
	printf("Motor driver 1 phase/direction: %d\r\n", phase);

	// Debug: timer period and prescaler
	uint32_t timer_period = __HAL_TIM_GET_AUTORELOAD(htim);
	uint32_t timer_prescaler = htim->Init.Prescaler;
	printf("[DEBUG] Timer period: %lu, prescaler: %lu\r\n", timer_period, timer_prescaler);

	// Calculate compare value based on timer period
	uint32_t compare_value = (timer_period * duty) / 100;
	printf("[DEBUG] Calculated compare value: %lu\r\n", compare_value);

	// Debug: PWM channel
	printf("[DEBUG] PWM channel: %lu\r\n", channel);

	// Set PWM duty cycle
	__HAL_TIM_SET_COMPARE(htim, channel, compare_value);

	// Start PWM output
	HAL_StatusTypeDef pwm_result = HAL_TIM_PWM_Start(htim, channel);
	printf("[DEBUG] HAL_TIM_PWM_Start result: %d\r\n", pwm_result);
	if (pwm_result != HAL_OK) {
		printf("ERROR: Failed to start PWM\r\n");
		return 0;
	}

	printf("Motor speed set to %d%% (Compare: %lu/%lu)\r\n",
		   duty, compare_value, timer_period);

	// Debug: Output pin state
	GPIO_PinState pwm_pin_state = HAL_GPIO_ReadPin(MD1_EN_IN1_GPIO_Port, MD1_EN_IN1_Pin);
	printf("[DEBUG] PWM output pin (MD1_EN_IN1) state: %d\r\n", pwm_pin_state);

	return duty;
}
